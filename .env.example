# ==========================================
# ATRIA - Environment Configuration
# ==========================================

# Environment: 'development' (local dev), 'test' (running tests), or 'production'
# CRITICAL: If set to 'production', local auto-login is completely disabled for security.
ATRIA_ENV=development

# Default identity for the system.
# 1. CLI: Defines the owner context for commands (if -u flag is omitted).
# 2. WEB: Automatically logs in this user IF and ONLY IF ATRIA_ENV=development.
ATRIA_USER=admin@atria.local

# Port on which the web server will listen
PORT=8080

# ==========================================
# DATABASE
# Format: postgres://user:password@host:port/database?sslmode=disable
# ==========================================
# Main database for running the application
DATABASE_URL=postgres://atria_user:secretpassword@localhost:5432/atria_dev?sslmode=disable

# Dedicated database ONLY for unit/integration tests
# WARNING: Tests will ruthlessly wipe this database (TRUNCATE) before each run!
TEST_DATABASE_URL=postgres://atria_user:secretpassword@localhost:5432/atria_test?sslmode=disable

# ==========================================
# STORAGE
# ==========================================
# Path to the directory where binary attachments, epub exports, etc. will be physically stored.
# Can be relative (./data/attachments) or absolute (/var/lib/atria/attachments)
STORAGE_PATH=./data/attachments

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================
# Režim přihlašování: "proxy" (jen Authelia), "local" (jen nativní login), "mixed" (obojí)
AUTH_MODE=mixed

# --- Local Auth ---
# Random string for signing JWT tokens or sessions.
SESSION_SECRET=super-secret-dev-key-change-me

# --- SSO / Proxy Auth ---
# Comma-separated list of trusted proxy IP addresses or CIDR blocks.
TRUSTED_PROXIES=127.0.0.1,::1
PROXY_AUTH_HEADER=Remote-Email
# URL for user managment link
SSO_MANAGEMENT_URL=https://auth.profant.eu
SSO_LOGOUT_URL=https://auth.profant.eu/logout
