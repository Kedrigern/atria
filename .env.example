# ==========================================
# ATRIA - Environment Configuration
# ==========================================

# Environment: 'development' (local dev), 'test' (running tests), or 'production'
# CRITICAL: If set to 'production', local auto-login is completely disabled for security.
ATRIA_ENV=development

# Default identity for the system.
# 1. CLI: Defines the owner context for commands (if -u flag is omitted).
# 2. WEB: Automatically logs in this user IF and ONLY IF ATRIA_ENV=development.
ATRIA_USER=admin@atria.local

# Port on which the web server will listen
PORT=8080

# Enable verbose debug logging (prints auth decisions, IP matching, etc.)
# Safe to enable in production temporarily for troubleshooting. Does NOT affect auth behaviour.
# DEBUG=true

# ==========================================
# DATABASE
# Format: postgres://user:password@host:port/database?sslmode=disable
# ==========================================
# Main database for running the application
DATABASE_URL=postgres://atria_user:secretpassword@localhost:5432/atria_dev?sslmode=disable

# Dedicated database ONLY for unit/integration tests
# WARNING: Tests will ruthlessly wipe this database (TRUNCATE) before each run!
TEST_DATABASE_URL=postgres://atria_user:secretpassword@localhost:5432/atria_test?sslmode=disable

# ==========================================
# STORAGE
# ==========================================
# Path to the directory where binary attachments, epub exports, etc. will be physically stored.
# Can be relative (./data/attachments) or absolute (/var/lib/atria/attachments)
STORAGE_PATH=./data/attachments

# ==========================================
# SECURITY
# ==========================================
# Random string for signing session cookies and CSRF tokens.
# In production, generate with: openssl rand -hex 32
SESSION_SECRET=super-secret-dev-key-change-me

# ==========================================
# SSO / PROXY AUTH (Authelia, Authentik, etc.)
# ==========================================
# Comma-separated list of IPs that Gin should treat as reverse proxies when resolving
# the real client IP from X-Forwarded-For. Typically your Angie/Nginx/Traefik IP.
TRUSTED_PROXIES=127.0.0.1,::1

# Comma-separated list of IPs allowed to inject proxy auth headers (Remote-Email etc.).
# Atria checks the raw TCP connection address (RemoteAddr), NOT the unwrapped client IP,
# so this should be the IP of your reverse proxy as seen by the Atria process.
# CRITICAL: If left empty, proxy header auth is completely disabled.
PROXY_ALLOWLIST=127.0.0.1,::1

# The HTTP header injected by your reverse proxy containing the authenticated user's email.
# Defaults to 'Remote-Email' if not set (standard Authelia header).
PROXY_AUTH_HEADER=Remote-Email

# URL shown as the "manage your account" link on the profile page.
SSO_MANAGEMENT_URL=https://auth.example.com

# URL to redirect the user to after logout (Authelia's logout endpoint).
SSO_LOGOUT_URL=https://auth.example.com/logout
